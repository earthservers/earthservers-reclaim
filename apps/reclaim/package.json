{
  "name": "reclaim",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:noscript": "mkdir -p src-tauri/resources/noscript && cargo build --release --manifest-path ../../crates/earth-noscript-ext/Cargo.toml && cp ../../crates/earth-noscript-ext/target/release/libearth_noscript_ext.so src-tauri/resources/noscript/libearth_noscript_ext.so",
    "dev:mock": "VITE_USE_MOCK_DATA=true vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "desktop": "GDK_BACKEND=x11 tauri dev",
    "desktop:x11": "GDK_BACKEND=x11 tauri dev",
    "desktop:wayland": "tauri dev",
    "desktop:prod": "GDK_BACKEND=x11 VITE_USE_MOCK_DATA=false tauri dev",
    "build:desktop": "VITE_USE_MOCK_DATA=false tauri build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@earthservers/ai-runtime": "workspace:*",
    "@earthservers/database": "workspace:*",
    "@earthservers/knowledge-graph": "workspace:*",
    "@earthservers/search-engine": "workspace:*",
    "@earthservers/ui": "workspace:*",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "@tauri-apps/plugin-http": "^2.5.4",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}
