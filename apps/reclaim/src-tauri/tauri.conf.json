{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reclaim",
  "version": "1.0.0",
  "identifier": "com.earthservers.reclaim",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "maximized": true,
        "resizable": true,
        "title": "Reclaim",
        "width": 1920,
        "height": 1080,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "backgroundColor": [10, 10, 15, 255],
        "incognito": true,
        "devtools": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/domain-lists/*"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/earthservers/earthservers-reclaim/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0NDM3Mzk1NDhDMTY4RTIKUldUaWFNRklsWE5EZFBlenRjUjBZMjZGamYyM3ZBWk13bUY4RkpRYWhlUlJFY3kvc3JXU2NBZ3cK"
    }
  }
}
