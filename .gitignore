# Lock files (optional - uncomment if you want to ignore)
# pnpm-lock.yaml

# Rust
# Cargo.lock IS committed — this is an application (binary), so a pinned lockfile
# gives reproducible CI builds. Without it, CI resolves deps fresh every run and a
# newly-published broken transitive dep (e.g. `cookie`) fails the build.
**/*.rs.bk

# Generated NoScript web-extension .so (built by build:noscript at bundle time)
apps/reclaim/src-tauri/resources/noscript/

# Autogenerated per-command ACL permissions (rewritten by src-tauri/build.rs on
# every build from the command list there). Only the hand-written set file
# (permissions/all-app-commands.toml) is committed.
apps/reclaim/src-tauri/permissions/autogenerated/
