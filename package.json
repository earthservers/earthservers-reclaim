{
  "name": "earthservers-reclaim",
  "version": "0.1.0",
  "private": true,
  "description": "Earth Reclaim - Privacy-first browser with local AI",
  "author": "EarthServers",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "turbo run test",
    "reclaim": "pnpm --filter reclaim tauri:dev",
    "reclaim:x11": "GDK_BACKEND=x11 WEBKIT_DISABLE_COMPOSITING_MODE=1 pnpm --filter reclaim tauri:dev",
    "reclaim:build": "bash scripts/build-release.sh",
    "desktop": "pnpm --filter reclaim tauri:dev",
    "desktop:x11": "GDK_BACKEND=x11 pnpm --filter reclaim tauri:dev",
    "desktop:build": "bash scripts/build-release.sh"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@turbo/gen": "^1.11.2",
    "prettier": "^3.1.1",
    "turbo": "^1.11.2",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@10.23.0"
}
